{% comment %}
    snippets/product-variants.liquid

    Snippet that renders product variants and size chart.

    Accepts:
    - product: {Object} Product Liquid object
    - Section: {Object} Section object
    - block: {Object} Block object
    - current_variant: {Object} Variant liquid object
    - show_size_chart: {Boolean} For showing the size chart
    - size_chart_label: {String} String for size chart label
    - size_chart_page: {Object} Page object from input setting
    - size_chart_type: {String} Size chart type
    - section_id: {String} Unique section ID so that popup are different

    Usage:
    {%
      render 'product-variants',
      product: product,
      section: section,
      block: block,
      current_variant: current_variant,
      show_size_chart: show_size_chart,
      size_chart_label: size_chart_label,
      size_chart_page: size_chart_page,
      section_id: section.id
    %}
{% endcomment %}
{% render 'snip-product-json', product: product %}
{%- unless product.has_only_default_variant -%}
 {%- if settings.product_variants == 'swatches' -%}
   <div
    class="product__variants-swatches mt4 mb6 no-js-hidden"
    data-section="{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-url="{{ product.url }}"
    data-selected-variant-id="{{ current_variant.id }}"
   >
     {% for option in product.options_with_values %}
       {% render "swatch",
         option: option,
         current_variant: current_variant,
         product: product,
         show_size_chart: show_size_chart,
         size_chart_label: size_chart_label,
         size_chart_page: size_chart_page,
         size_chart_type: size_chart_type,
         section_id: section_id
        %}
     {% endfor %}
   </div>
 {%- else -%}
   <div
    class="product__variants-select no-js-hidden selector-wrapper"
    data-section="{{ section.id }}"
    data-url="{{ product.url }}"
    data-section-id="{{ section.id }}"
   >
     <div class="input-holder">
       <div class="container">
         <p class="plus-line-item-property__field">
           <label for="com-height-{{ section.id }}" class="plus-line-item-property__label"> HEIGHT</label>
           <input
             required
             class="required plus-line-item-property__input"
             id="com-height-{{ section.id }}"
             type="number"
             name="items[0]properties[height]"
             placeholder="Inches"
             form="{{ product_buttons_form_id }}"
             data-product-property
           >
         </p>

        <span class="com-dimension-separator">X</span>


         <p class="plus-line-item-property__field ml20">
           <label for="com-width-{{ section.id }}" class="plus-line-item-property__label">WIDTH</label>
           <input
             required
             class="required plus-line-item-property__input"
             id="com-width-{{ section.id }}"
             type="number"
             name="items[0]properties[width]"
             placeholder="Inches"
             form="{{ product_buttons_form_id }}"
             data-product-property
           >
         </p>
       </div>
     </div>

     {%- for option in product.options_with_values -%}
       {% unless template == 'product.quick' %}
        {% assign option_name = option.name | downcase %}
        {% assign size_swatches = "size, sizes, talla, taglia, taille, tamanho, grosse" | split: ", " %}
          {% if show_size_chart and size_swatches contains option_name %}
              {% render 'size-chart', label: size_chart_label, page: size_chart_page, section_id: section_id, type: size_chart_type %}
          {% endif %}
        {% endunless %}
       <div class="product-form__input product-form__input--dropdown">
         <label
          class="form__label"
          for="Option-{{ section.id }}-{{ forloop.index0 }}">
           {{ option.name }}
         </label>
          <div class="select">
              <select id="Option-{{ section.id }}-{{ forloop.index0 }}"
                style= "margin-bottom: 20px;"
                class="js-variant-selector styled-select"
                name="options[{{ option.name | escape }}]"
                form="product-form-{{ section.id }}"
              >
                {%- for option_value in option.values -%}
                  <option
                    value="{{ option_value | escape }}"
                    {% if option.selected_value == option_value %}
                      selected="selected"
                    {% endif %}
                    data-position="{{ option.position }}"
                    data-option-value-id="{{ option_value.id }}"
                    name="{{ option.name | downcase | escape }}"
                  >
                    {% if option_value.available %}
                      {{ option_value }}
                    {% else %}
                      {{ option_value }} - Unavailable
                    {% endif %}
                  </option>
                {%- endfor -%}
              </select>
           </div>
       </div>

       {% case option_name %}
         {% when 'edge finish' %}
          <p class="com-input__field">
            <label for="face-fabric-name-{{ section.id }}" class="a-left">FACE FABRIC NAME</label>
            <input
              required
              class="required plus-line-item-property__input"
              id="face-fabric-name-{{ section.id }}"
              type="text"
              name="items[0]properties[Face Fabric Name]"
              form="{{ product_buttons_form_id }}"
              data-product-property
            >
          </p>

          <p class="com-input__field">
            <label for="face-fabric-link-{{ section.id }}" class="a-left">FACE FABRIC LINK</label>
            <input
              class="plus-line-item-property__input"
              id="face-fabric-link-{{ section.id }}"
              type="url"
              name="items[0]properties[Face Fabric Link]"
              placeholder="https://"
              form="{{ product_buttons_form_id }}"
              data-product-property
            >
          </p>

          <p class="com-input__field">
            <label for="reverse-fabric-name-{{ section.id }}" class="a-left">REVERSE FABRIC NAME</label>
            <input
              required
              class="required plus-line-item-property__input"
              id="reverse-fabric-name-{{ section.id }}"
              type="text"
              name="items[0]properties[Reverse Fabric Name]"
              form="{{ product_buttons_form_id }}"
              data-product-property
            >
          </p>

          <p class="com-input__field">
            <label for="reverse-fabric-link-{{ section.id }}" class="a-left">REVERSE FABRIC LINK</label>
            <input
              class="plus-line-item-property__input"
              id="reverse-fabric-link-{{ section.id }}"
              type="url"
              name="items[0]properties[Reverse Fabric Link]"
              placeholder="https://"
              form="{{ product_buttons_form_id }}"
              data-product-property
            >
          </p>

          <p class="com-input__field com-edge-finish-field" style="display: none;">
            <label for="edge-finish-fabric-material-{{ section.id }}" class="a-left">EDGE FINISH FABRIC/MATERIAL</label>
            <input
              class="required plus-line-item-property__input"
              id="edge-finish-fabric-material-{{ section.id }}"
              type="text"
              name="items[0]properties[Edge Finish Fabric/material]"
              form="{{ product_buttons_form_id }}"
              data-product-property
              data-com-required
              disabled
            >
          </p>

          <p class="com-input__field com-edge-finish-field" style="display: none;">
            <label for="edge-finish-fabric-material-link-{{ section.id }}" class="a-left">EDGE FINISH FABRIC/MATERIAL LINK</label>
            <input
              class="plus-line-item-property__input"
              id="edge-finish-fabric-material-link-{{ section.id }}"
              type="url"
              name="items[0]properties[Edge Finish Fabric/material Link]"
              placeholder="https://"
              form="{{ product_buttons_form_id }}"
              data-product-property
              disabled
            >
          </p>

         {% when 'tape trim' %}
          <p class="com-input__field com-trim-field" style="display: none;">
             <label for="trim-name-{{ section.id }}" class="a-left"> TRIM NAME</label>
             <input
               class="required plus-line-item-property__input"
               id="trim-name-{{ section.id }}"
               type="text"
               name="items[0]properties[Trim Name]"
               form="{{ product_buttons_form_id }}"
               data-product-property
               data-com-required
               disabled
             >
           </p>

          <p class="com-input__field com-trim-field" style="display: none;">
             <label for="trim-link-{{ section.id }}" class="a-left"> TRIM LINK</label>
             <input
               class="plus-line-item-property__input"
               id="trim-link-{{ section.id }}"
               type="url"
               name="items[0]properties[Trim Link]"
               placeholder="https://"
               form="{{ product_buttons_form_id }}"
               data-product-property
               disabled
             >
           </p>

          <p class="com-input__field com-inset-field" style="display: none;">
             <label for="inset-from-edge-{{ section.id }}" class="a-left"> INSET FROM EDGE</label>
             <input
               class="required plus-line-item-property__input"
               id="inset-from-edge-{{ section.id }}"
               type="number"
               name="items[0]properties[Inset From Edge]"
               placeholder="Inches"
               form="{{ product_buttons_form_id }}"
               data-product-property
               data-com-required
               disabled
             >
           </p>

         {% when 'box band' %}
           <p class="com-input__field com-box-band-field" style="display: none;">
             <label for="box-band-fabric-name-{{ section.id }}" class="a-left"> BOX BAND FABRIC NAME</label>
             <input
               class="required plus-line-item-property__input"
               id="box-band-fabric-name-{{ section.id }}"
               type="text"
               name="items[0]properties[Box Band Fabric Name]"
               form="{{ product_buttons_form_id }}"
               data-product-property
               data-com-required
               disabled
             >
           </p>

           <p class="com-input__field com-box-band-field" style="display: none;">
             <label for="box-band-fabric-link-{{ section.id }}" class="a-left"> BOX BAND FABRIC LINK</label>
             <input
               class="plus-line-item-property__input"
               id="box-band-fabric-link-{{ section.id }}"
               type="url"
               name="items[0]properties[Box Band Fabric Link]"
               placeholder="https://"
               form="{{ product_buttons_form_id }}"
               data-product-property
               disabled
             >
           </p>

           <p class="com-input__field com-box-band-field" style="display: none;">
             <label for="box-band-width-{{ section.id }}" class="a-left"> BOX BAND WIDTH</label>
             <input
               class="required plus-line-item-property__input"
               id="box-band-width-{{ section.id }}"
               type="text"
               name="items[0]properties[Box Band Width]"
               form="{{ product_buttons_form_id }}"
               data-product-property
               data-com-required
               disabled
             >
           </p>
      {% endcase %}
    {%- endfor -%}

    <p class="com-input__field">
      <label for="special-notes-{{ section.id }}" class="a-left">SPECIAL NOTES</label>
      <textarea
        class="plus-line-item-property__input plus-line-item-property__text-area"
        id="special-notes-{{ section.id }}"
        name="items[0]properties[Special Notes]"
        form="{{ product_buttons_form_id }}"
        data-product-property
      ></textarea>
    </p>
  </div>
{%- endif -%}
{%- endunless -%}

<input
class="formVariantId"
name=""
type="hidden"
value="{{ current_variant.id }}">
