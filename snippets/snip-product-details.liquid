{% comment %}

    Product Details Block Snippet
    ----------------------------------------------------------

    Objects:
    - block: The product details block settings and properties
    - product: The current product object

    Settings:
    - show_as_accordion: Boolean to determine if the block should be displayed as an accordion
    - default_open_accordion: Boolean to determine if the accordion should be open by default

    Usage:
    {% render 'snip-product-details', block: block, product: product %}

{% endcomment %}

<div
  class="product-blocks__block product-blocks__block--{{ block.type }} {% if block.settings.show_as_accordion %}product-blocks__block--accordion-item{% endif %}"
>

  {% if block.settings.show_as_accordion %}

    <details
      class="details details--fade"
      id="{{ block.id }}"
      {% if block.settings.default_open_accordion %}
          open
      {% endif %}
      data-default-open-accordion="{{ block.settings.default_open_accordion }}"
      {{ block.shopify_attributes }}
    >
      <summary class="details__summary">
        <h3 class="details__title">{{ 'products.product.product_details' | t }}</h3>
        <div class="details__icon">
          {% render 'snip-icons',
              wrapper: '',
              type: 'apollo',
              icon: 'minus',
              classes: 'details__svg open c-accordion__header-icons--icon',
              size: '14px',
              fill: 'var(--accordion-color)',
              hover: 'var(--accordion-color)' %}
          {% render 'snip-icons',
              wrapper: '',
              type: 'apollo',
              icon: 'plus',
              classes: 'details__svg closed c-accordion__header-icons--icon',
              size: '14px',
              fill: 'var(--accordion-color)',
              hover: 'var(--accordion-color)' %}
        </div>
      </summary>
      <div class="details__content rte">
        {%
          render 'product-details',
          block: block,
          product: product
        %}
      </div>
    </details>
  {% else %}
    <h5 class="h5">{{ 'products.product.product_details' | t }}</h5>
    {%
      render 'product-details',
      block: block,
      product: product
    %}
  {% endif %}
</div><!-- /.product-blocks__block -->
<div class="clear"></div>