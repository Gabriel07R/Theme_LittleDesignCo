{%- liquid
  assign sample_label = 'Sample 4" X 4"'
  assign alternate_sample_label = '4" X 4" Sample'
  assign sample_label_downcase = sample_label | downcase
  assign alternate_sample_label_downcase = alternate_sample_label | downcase
  assign sample_variant_id = ''
  assign sample_variant_count = 0
  assign color_option_index = ''
  assign color_swatch_options = settings.swatch_option_names | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ','

  for option in product.options
    assign option_downcase = option | downcase
    if color_swatch_options contains option_downcase
      assign color_option_index = forloop.index0
      break
    endif
  endfor

  for variant in product.variants
    assign is_sample_variant = false

    if variant.available
      for option_value in variant.options
        assign option_value_downcase = option_value | downcase
        if option_value_downcase == sample_label_downcase or option_value_downcase == alternate_sample_label_downcase
          assign is_sample_variant = true
          break
        endif
      endfor
    endif

    if is_sample_variant
      assign sample_variant_count = sample_variant_count | plus: 1
      if sample_variant_id == ''
        assign sample_variant_id = variant.id
      endif
    endif
  endfor
-%}

{%- if sample_variant_id != '' -%}
  {%- capture sample_button_icon -%}
      <span class="product-sample-button__icon product-sample-button__icon--default">
        {% render 'snip-icons',
          wrapper: '.product-sample-button',
          type: 'vantage-theme',
          icon: 'white-sample',
          classes: '',
          size: '18px',
          fill: 'currentColor',
          hover: 'currentColor'
        %}
      </span>
      <span class="product-sample-button__icon product-sample-button__icon--hover">
        {% render 'snip-icons',
          wrapper: '.product-sample-button',
          type: 'vantage-theme',
          icon: 'black-sample',
          classes: '',
          size: '18px',
          fill: 'currentColor',
          hover: 'currentColor'
        %}
      </span>
      <span class="visually-hidden">Add sample to cart</span>
  {%- endcapture -%}

  {%- if sample_variant_count > 1 -%}
    <details class="product-sample-form product-sample-form--card product-sample-picker--card">
      <summary
        class="product-sample-button product-sample-button--card"
        data-tooltip="Add sample"
        aria-label="Choose a sample color for {{ product.title | escape }}"
      >
        {{ sample_button_icon }}
      </summary>

      <div class="product-sample-options" role="list" aria-label="Sample color options">
        <p class="product-sample-options__title">Reverse Colorway</p>
        {%- liquid
          assign rendered_sample_options = ''
        -%}
        {%- for variant in product.variants -%}
          {%- liquid
            assign is_sample_variant = false

            if variant.available
              for option_value in variant.options
                assign option_value_downcase = option_value | downcase
                if option_value_downcase == sample_label_downcase or option_value_downcase == alternate_sample_label_downcase
                  assign is_sample_variant = true
                  break
                endif
              endfor
            endif

            assign sample_option_label = variant.title
            if color_option_index != ''
              assign sample_option_label = variant.options[color_option_index]
            endif
            assign sample_color_label = sample_option_label | strip
            assign sample_color_label = sample_color_label | remove: 'Sample 4" X 4" / Butterfly Flange /'
            assign sample_color_label = sample_color_label | remove: 'Sample 4" X 4" / Cording /'
            assign sample_color_label = sample_color_label | remove: 'SAMPLE 4" X 4" / BUTTERFLY FLANGE /'
            assign sample_color_label = sample_color_label | remove: 'SAMPLE 4" X 4" / CORDING /'
            assign sample_color_label = sample_color_label | replace: 'Rosé Pink', 'Rose Pink' | strip
            assign sample_color_label_downcase = sample_color_label | downcase
            assign sample_option_key = '|' | append: sample_color_label | append: '|'
            assign image_name = sample_color_label | replace: ' ', '_' | prepend: 'CL_' | append: '.png'
            assign image_url = image_name | file_url
            assign bg_image_rule = ''
            assign swatch_class = 'product-sample-option__swatch'
            if sample_color_label_downcase == 'self' and product.featured_image != blank
              assign image_url = product.featured_image | image_url: width: 160
              assign bg_image_rule = 'background-image: url(' | append: image_url | append: ');'
              assign swatch_class = swatch_class | append: ' product-sample-option__swatch--self'
            elsif settings.color_swatch_style == 'custom-image' and image_url != blank
              assign bg_image_rule = 'background-image: url(' | append: image_url | append: ');'
            endif
          -%}
          {%- if is_sample_variant -%}
            {%- unless rendered_sample_options contains sample_option_key -%}
              <form class="product-sample-option-form" action="/cart/add" method="post">
                <input class="formVariantId" type="hidden" name="items[0][id]" value="{{ variant.id }}">
                <input class="formQty" type="hidden" name="items[0][quantity]" value="1">
                <div class="note note-success js-added-msg" style="display: none">
                  <strong>{{ 'products.product.added' | t }}</strong>
                </div>
                <div class="note note-error js-error-msg" style="display: none">
                  <strong>{{ 'cart.general.cart_error' | t }}</strong> {{ 'cart.general.update_qty_error' | t }}
                </div>
                <button
                  type="submit"
                  class="product-sample-option AddtoCart js-ajax-submit"
                  name="button"
                  value="{{ sample_color_label | escape }}"
                  data-quick-add
                  data-sample-cart-notification="Sample added to cart"
                  data-colorway-tooltip="{{ sample_color_label | escape }}"
                  aria-label="Add {{ sample_color_label | escape }} sample for {{ product.title | escape }} to cart"
                >
                  <span
                    class="{{ swatch_class }}"
                    style="{{ bg_image_rule }}"
                    aria-hidden="true"
                  ></span>
                  <span class="visually-hidden">{{ sample_color_label }}</span>
                </button>
              </form>
              {%- assign rendered_sample_options = rendered_sample_options | append: sample_option_key -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </details>
  {%- else -%}
    <form class="product-sample-form product-sample-form--card" action="/cart/add" method="post">
      <input class="formVariantId" type="hidden" name="items[0][id]" value="{{ sample_variant_id }}">
      <input class="formQty" type="hidden" name="items[0][quantity]" value="1">
      <div class="note note-success js-added-msg" style="display: none">
        <strong>{{ 'products.product.added' | t }}</strong>
      </div>
      <div class="note note-error js-error-msg" style="display: none">
        <strong>{{ 'cart.general.cart_error' | t }}</strong> {{ 'cart.general.update_qty_error' | t }}
      </div>
      <button
        type="submit"
        class="product-sample-button product-sample-button--card AddtoCart js-ajax-submit"
        name="button"
        value="Sample"
        data-quick-add
        data-sample-cart-notification="Sample added to cart"
        data-tooltip="Add sample"
        aria-label="Add {{ sample_label | escape }} sample for {{ product.title | escape }} to cart"
      >
        {{ sample_button_icon }}
      </button>
    </form>
  {%- endif -%}
{%- endif -%}
